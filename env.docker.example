# Cinefile - Docker Environment Configuration
# Copy this file to .env.docker and fill in your values

# ===========================================
# Required Configuration
# ===========================================

# TMDb API Key
# Get your free API key from: https://www.themoviedb.org/settings/api
# This is required for searching movies and fetching metadata
TMDB_API_KEY=your_tmdb_api_key_here

# Admin Password
# Set a secure password for the admin panel
# This will be used to log into /admin
ADMIN_PASSWORD=your_secure_password_here

# ===========================================
# Optional Configuration
# ===========================================

# Read-Only Port (Public-facing)
# Port to expose the read-only server on the host
# This server only exposes GET endpoints - safe for public internet
# The server always listens on port 3000 inside the container
# Default: 3000
# Change this if port 3000 is already in use on your host
READ_ONLY_PORT=3000

# Admin Port (Full API - Internal/VPN only)
# Port to expose the full API server on the host
# This server has all CRUD operations - should be restricted to VPN/internal network
# The server always listens on port 3001 inside the container
# Default: 3001
# WARNING: Do not expose this port to the public internet!
# To expose this port, uncomment the admin port mapping in docker-compose.yml
# and ensure it's protected by firewall rules or VPN access
ADMIN_PORT=3001

# ===========================================
# Internal Configuration (Advanced)
# ===========================================
# These are configured automatically by Docker
# You generally don't need to change these

# Database path (internal)
# DATABASE_PATH=/data/database.sqlite

# Upload directory (internal)
# UPLOAD_DIR=/data/uploads

# Node environment
# NODE_ENV=production

